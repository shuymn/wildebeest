{
	"name": "wildebeest",
	"version": "0.1.0",
	"type": "module",
	"author": "Sven Sauleau <sven@cloudflare.com>",
	"devDependencies": {
		"@cloudflare/pages-plugin-cloudflare-access": "1.0.5",
		"lefthook": "2.1.9",
		"npm-run-all2": "8.0.4",
		"prettier": "3.8.4",
		"sql-formatter": "15.8.2",
		"wrangler": "4.105.0"
	},
	"private": true,
	"scripts": {
		"pretty": "npx prettier --list-different './**/*.{ts,tsx,js,jsx,json,css}'",
		"test": "NODE_OPTIONS=--experimental-vm-modules vitest run",
		"lint": "run-p lint:* --print-label",
		"lint:frontend": "pnpm --filter @wildebeest/frontend lint",
		"lint:backend": "pnpm --filter @wildebeest/backend lint",
		"lint:consumer": "pnpm --filter @wildebeest/consumer lint",
		"lint:do": "pnpm --filter @wildebeest/do lint",
		"test:ui": "pnpm --filter @wildebeest/frontend test:e2e",
		"build": "pnpm --filter @wildebeest/frontend build",
		"d1": "NO_D1_WARNING=true wrangler d1",
		"pages": "NO_D1_WARNING=true wrangler pages",
		"database:migrate": "pnpm run d1 -- migrations apply DATABASE",
		"database:create-mock": "bash scripts/database-create-mock.sh",
		"database:generate-query": "sqlc generate",
		"predev": "mv .dev.vars.bak .dev.vars || true",
		"dev": "bash scripts/dev.sh",
		"preci-dev-test-ui": "mv .dev.vars .dev.vars.bak || true",
		"ci-dev-test-ui": "bash scripts/ci-dev-test-ui.sh",
		"postci-dev-test-ui": "mv .dev.vars.bak .dev.vars || true",
		"deploy:init": "pnpm run pages -- project create wildebeest && pnpm run d1 -- create wildebeest",
		"deploy": "bash scripts/deploy.sh",
		"prepare": "lefthook install"
	},
	"packageManager": "pnpm@10.28.0"
}

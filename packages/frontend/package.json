{
	"name": "@wildebeest/frontend",
	"description": "App with Routing built-in (recommended)",
	"type": "module",
	"engines": {
		"node": ">=24.17.0"
	},
	"private": true,
	"scripts": {
		"pretypes-check": "pnpm --dir ../.. --filter @wildebeest/backend exec tsc -b && pnpm run build",
		"types-check": "tsc --noEmit",
		"lint": "eslint src mock-db adapters",
		"build": "vite build && vite build --config adapters/cloudflare-pages/vite.config.ts",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@builder.io/qwik": "1.20.0",
		"@playwright/test": "1.61.1",
		"@builder.io/qwik-city": "1.20.0",
		"@types/eslint": "9.6.1",
		"@types/node": "24.13.2",
		"@typescript-eslint/eslint-plugin": "8.62.0",
		"@typescript-eslint/parser": "8.62.0",
		"autoprefixer": "10.5.2",
		"eslint": "9.39.4",
		"eslint-plugin-qwik": "1.20.0",
		"hono": "4.12.27",
		"lorem-ipsum": "2.0.10",
		"postcss": "8.5.15",
		"prettier": "3.8.5",
		"sass": "1.101.0",
		"tailwindcss": "3.4.19",
		"typescript": "5.9.3",
		"undici": "8.5.0",
		"vite": "8.1.0",
		"vite-tsconfig-paths": "6.1.1"
	},
	"dependencies": {
		"@wildebeest/backend": "workspace:*",
		"modern-normalize": "3.0.1"
	}
}
